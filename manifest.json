{
  "manifest_version": 3,
  "name": "SmartCart AI — Grocery Price Agent",
  "version": "7.0.1",
  "description": "Reads your Zepto cart, searches Blinkit & Swiggy for the same items, finds cheapest.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://*.zeptonow.com/*",
    "https://*.zepto.com/*",
    "https://*.blinkit.com/*",
    "https://*.blinkit.in/*",
    "https://*.grofers.com/*",
    "https://*.swiggy.com/*",
    "https://*.swiggy.in/*"
  ],
  "background": { "service_worker": "background/agent.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.zeptonow.com/*",
        "https://*.zepto.com/*",
        "https://*.blinkit.com/*",
        "https://*.blinkit.in/*",
        "https://*.grofers.com/*",
        "https://*.swiggy.com/*",
        "https://*.swiggy.in/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
